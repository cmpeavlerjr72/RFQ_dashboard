# Server
PORT=8090

# Kalshi (must match what your Python runners use)
KALSHI_ENV=PROD
KALSHI_API_KEY_ID=

# Provide ONE of the following two:
#   1) Full PEM as an env var (Render-friendly). Newlines must be literal \n
#      when stored in the env var (the server replaces them).
KALSHI_PRIVATE_KEY=

#   2) File path. For Render, use a Secret File at /etc/secrets/kalshi.pem.
KALSHI_PRIVATE_KEY_PATH=

# Optional: where to read fills.jsonl. Empty = no local fills file (deploy mode).
FILLS_PATH=

# Optional: HF read for fills history (not used by server today; kept for parity)
HF_TOKEN=
HF_REPO_ID=mvpeav/kalshi-rfq-fills
