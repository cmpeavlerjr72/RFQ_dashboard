# Server
PORT=8090

# Kalshi — primary account (MVPeav). Must match what your Python runners use.
KALSHI_ENV=PROD
KALSHI_API_KEY_ID=...
KALSHI_PRIVATE_KEY_PATH=../kalshi_private_key.pem
# On Render you can instead supply the PEM inline (escape newlines as \n):
# KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Kalshi — second account (TGPeav). Same convention with a _SECOND suffix.
# The header account switcher routes per-request to whichever is selected.
KALSHI_API_KEY_ID_SECOND=...
KALSHI_PRIVATE_KEY_PATH_SECOND=../kalshi_private_key_SECOND.pem
# KALSHI_PRIVATE_KEY_SECOND="-----BEGIN PRIVATE KEY-----\n...\n"

# Optional: per-account local fills files for the live open-positions fast-path.
# Both are optional — positions + legs come from Kalshi regardless.
# FILLS_PATH=../data/fills.jsonl                 # MVPeav (default)
# FILLS_PATH_TGPEAV=../data/fills_tgpeav.jsonl   # TGPeav

# Optional: HF read for fills history
HF_TOKEN=
HF_REPO_ID=mvpeav/kalshi-rfq-fills
